# Скопируйте в `.env` и при необходимости измените значения.
# Файл `.env` не коммитится (см. `.gitignore`).

# Учётные данные БД (Spring Boot и контейнер Postgres в docker-compose)
DB_USER=template-app-user
DB_PASSWORD=template-app-password

POSTGRES_DB=templatedb
POSTGRES_USER=template-app-user
POSTGRES_PASSWORD=template-app-password

# Spring Boot: JDBC URL (в application.properties через ${DB_URL}).
# Для `docker compose up` строку не задавайте — в compose подставляется хост `postgres`.
# Для локального запуска приложения (Maven/IDE) с Postgres на машине:
# DB_URL=jdbc:postgresql://localhost:5432/templatedb
