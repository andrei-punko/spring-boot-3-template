								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated title\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{service-url}}/api/v1/articles/{{article-id}}",
							"host": [
								"{{service-url}}"
							],
							"path": [
								"api",
								"v1",
								"articles",
								"{{article-id}}"
							]
						},
						"description": "В теле должно быть задано ровно одно из: `title`, `summary`, `text` (валидация `@OnlyOneFieldModified`). 200 OK, 400 или 404."
