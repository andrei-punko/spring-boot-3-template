		"name": "Spring Boot 3 Template — Articles API",
		"description": "Запросы к `ArticleController`: базовый путь `/api/v1/articles`. Создание — `ArticleDto` (без id и дат). Обновление — `ArticleUpdateDto`: ровно одно из полей `title`, `summary`, `text`. Пагинация: `page` (с 0), `size` (1–100, по умолчанию 50), `sort` (например `title,asc`, `author,DESC`).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "1701433"
	},
	"variable": [
		{
			"key": "article-id",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "Articles",
			"item": [
				{
					"name": "Create article",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Spring Boot tips\",\n  \"summary\": \"Short intro\",\n  \"text\": \"Long article body.\",\n  \"author\": \"jdoe\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{service-url}}/api/v1/articles",
							"host": [
								"{{service-url}}"
							],
							"path": [
								"api",
								"v1",
								"articles"
							]
						},
						"description": "201 Created. Поля `title`, `text`, `author` обязательны; `summary` опционально. Не передавайте `id`, `dateCreated`, `dateUpdated`."
					},
					"response": []
				},
				{
					"name": "Get article by id",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{service-url}}/api/v1/articles/{{article-id}}",
							"host": [
								"{{service-url}}"
							],
							"path": [
								"api",
								"v1",
								"articles",
								"{{article-id}}"
							]
						},
						"description": "200 OK или 404, если статья не найдена."
					},
					"response": []
				},
				{
					"name": "List articles (paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{service-url}}/api/v1/articles?page=0&size=2&sort=author,DESC",
							"host": [
								"{{service-url}}"
							],
							"path": [
								"api",
								"v1",
								"articles"
							],
							"query": [
								{
									"key": "page",
									"value": "0",
									"description": "Номер страницы, с 0"
								},
								{
									"key": "size",
									"value": "2",
									"description": "Размер страницы, 1–100 (по умолчанию на сервере 50)"
								},
								{
									"key": "sort",
									"value": "author,DESC",
									"description": "Если не указан — сортировка по `title` по возрастанию"
								}
							]
						},
						"description": "Возвращает `Slice<ArticleDto>` (Spring Data)."
					},
					"response": []
				},
				{
					"name": "Update article (PATCH)",
					"request": {
						"method": "PATCH",
						"header": [
